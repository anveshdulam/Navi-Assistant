# Offline mode (default true). Set to false to allow cloud providers.
OFFLINE_ONLY=true

# Client offline mode for COCO-SSD (default true).
NEXT_PUBLIC_OFFLINE_ONLY=true
NEXT_PUBLIC_COCO_SSD_MODEL_URL=/models/coco-ssd/model.json

# Local SmolVLM2 vision
SMOLVLM2_URL=
SMOLVLM2_MODEL_ID=HuggingFaceTB/SmolVLM2-2.2B-Instruct

# Cloud vision (choose one provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional ZAI vision
ZAI_API_KEY=
ZAI_BASE_URL=
ZAI_VISION_MODEL=

# Database
DATABASE_URL="file:./dev.db"
